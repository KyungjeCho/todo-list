# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=todolist
DATABASE_SSL=false

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# OAuth State Secret (defaults to JWT_SECRET if not set)
OAUTH_STATE_SECRET=

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/v1/auth/oauth/google/callback

# OAuth - Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=http://localhost:3000/v1/auth/oauth/naver/callback

# OAuth - Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:3000/v1/auth/oauth/kakao/callback

# OAuth - Apple
# Services ID (not Bundle ID)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# .p8 private key — use EITHER path (local dev) OR inline string (deploy). Not both.
APPLE_PRIVATE_KEY_PATH=
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
APPLE_PRIVATE_KEY=
# https only; must exactly match Return URL registered in Apple Developer console
APPLE_CALLBACK_URL=https://api.example.com/auth/oauth/apple/callback

# Firebase (FCM)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# AI (Gemini Flash - Google AI Studio)
GEMINI_API_KEY=

# App
APP_PORT=3000
APP_DEEP_LINK_SCHEME=todolist
